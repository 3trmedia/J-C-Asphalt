---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Residential Driveway Paving | J&C Asphalt | Utah Valley"
  description="New asphalt driveways installed by a full professional crew across Utah Valley. Most residential driveways completed in a single day. Free quotes available."
>
  <section class="service-hero">
    <div class="container">
      <span class="section-label">Residential Services</span>
      <h1 class="section-title">New Driveway. Done in a Day.</h1>
      <p>Most residential driveways are completed from sunup to sundown by our full crew. No waiting a week for a two-man operation to finish. We show up with the people and equipment to get it done.</p>
      <div class="hero-ctas">
        <a href="/contact" class="btn-primary">Get a Free Quote</a>
        <a href="/work" class="btn-outline">See Driveway Projects</a>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container">
      <div class="overview-inner">
        <div>
          <span class="section-label">Why J&amp;C for Driveways</span>
          <h2 class="section-title">Your Driveway Deserves a Real Crew</h2>
          <p>Small contractors often stretch a driveway job over 2–3 days because they don't have the manpower. We field 15+ trained crew members on every job, which means your driveway is typically finished the same day we start.</p>
          <p>From removing your old gravel or cracked asphalt to laying a smooth, professionally finished surface. We handle the full project.</p>
          <ul class="service-list">
            <li>Old surface demolition and removal</li>
            <li>Sub-base grading and compaction</li>
            <li>Hot-mix asphalt installation</li>
            <li>Smooth finish and edge detail</li>
            <li>Site cleanup before we leave</li>
            <li>Guidance on cure time and maintenance</li>
          </ul>
          <a href="/contact" class="btn-primary" style="margin-top: 2rem; display: inline-block;">Get a Driveway Quote</a>
        </div>
        <div>
          <img
            src="/images/driveway-completed-aerial.jpg"
            alt="Completed residential driveway paved by J&C Asphalt, aerial view"
            width="560"
            height="520"
            loading="lazy"
          />
          <div class="day-badge">
            <span class="badge-main">1 Day</span>
            <span class="badge-sub">Most Driveways</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad section-dark">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Common Questions</span>
        <h2 class="section-title">Driveway FAQ</h2>
      </div>
      <div class="faq-grid">
        {[
          { q: 'How long does a new driveway take?', a: 'Most residential driveways are completed in a single day with our full crew. Larger projects or those requiring significant excavation may take two days.' },
          { q: 'How soon can I drive on it?', a: 'We recommend waiting 24–48 hours before driving on a new asphalt driveway, and longer during hot summer months. We\'ll give you specific guidance for your project.' },
          { q: 'Do you handle demolition of the old driveway?', a: 'Yes. We remove and haul away your existing surface as part of the project. You don\'t need to arrange anything separately.' },
          { q: 'Do you service my area?', a: 'We serve the full Utah Valley corridor, Santaquin to Lehi, and are expanding into Salt Lake Valley. Check our Service Areas page or give us a call.' },
          { q: 'What\'s included in the quote?', a: 'Our free quotes include material costs, labor, equipment, demo (if needed), and cleanup. No hidden fees.' },
          { q: 'How long will my asphalt driveway last?', a: 'A properly installed and maintained asphalt driveway typically lasts 20–30 years. We install it right the first time so you get the full life out of it.' },
        ].map(item => (
          <div class="faq-item">
            <h3>{item.q}</h3>
            <p>{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Our Work</span>
        <h2 class="section-title">Driveway Projects</h2>
      </div>
      <div class="mini-gallery">
        {[
          { src: '/images/driveway-aerial-finished.jpg', alt: 'Aerial view of completed curved residential driveway with tennis court and green landscaping' },
          { src: '/images/paver-leeboy-side.jpg', alt: 'J&C Asphalt branded LeeBoy paver with crew working on a residential driveway' },
          { src: '/images/aerial-drone-paving.jpg', alt: 'Aerial view of orange asphalt paver in a residential driveway in Utah Valley' },
        ].map(({ src, alt }) => (
          <img
            src={src}
            alt={alt}
            width="560"
            height="380"
            loading="lazy"
          />
        ))}
      </div>
      <div style="text-align:center; margin-top: 2.5rem;">
        <a href="/work" class="btn-outline-red">View All Projects &rarr;</a>
      </div>
    </div>
  </section>

  <section class="service-cta">
    <div class="container">
      <h2>Get a Free Driveway Quote</h2>
      <p>Tell us your address and project details and we'll get you a written estimate, usually within 24 hours.</p>
      <a href="/contact" class="btn-primary" style="background:#000; color:#cd553f;">Get a Free Quote</a>
    </div>
  </section>
</Layout>

<style>
  .service-hero {
    padding: 8rem 0 5rem;
    background-color: #FFFFFF;
    border-bottom: 3px solid #cd553f;
  }

  .service-hero h1 { font-size: clamp(2rem, 4vw, 3rem); margin: 0.5rem 0 1rem; }
  .service-hero p { color: #666; font-size: 1.05rem; line-height: 1.7; max-width: 600px; margin-bottom: 1.75rem; }

  .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

  .section-pad { padding: 5rem 0; }
  .section-dark { background-color: #F2F5F2; }

  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3rem;
  }

  .overview-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .overview-inner h2 { margin: 0.5rem 0 1rem; }
  .overview-inner > div > p { color: #666; font-size: 0.95rem; line-height: 1.75; margin-bottom: 1rem; }

  .overview-inner > div:last-child {
    position: relative;
  }

  .overview-inner > div:last-child img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .day-badge {
    position: absolute;
    bottom: -1.5rem;
    right: -1.5rem;
    background-color: #cd553f;
    padding: 1.5rem 2rem;
    text-align: center;
  }

  .badge-main {
    display: block;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: #000;
    line-height: 1;
  }

  .badge-sub {
    display: block;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #000;
    margin-top: 0.25rem;
  }

  .service-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .service-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: #555;
  }

  .service-list li::before {
    content: '';
    width: 18px;
    height: 18px;
    background-image: url("data:image/svg+xml,%3Csvg width='18' height='18' viewBox='0 0 18 18' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M3 9l4 4 8-8' stroke='%23cd553f' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: center;
    flex-shrink: 0;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .faq-item {
    padding: 1.75rem;
    background-color: #FFFFFF;
    border: 1px solid #C8CEC8;
    border-left: 3px solid #cd553f;
  }

  .faq-item h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #121212;
    margin-bottom: 0.75rem;
  }

  .faq-item p {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.65;
    margin: 0;
  }

  .mini-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .mini-gallery img { width: 100%; height: 380px; object-fit: cover; object-position: center; display: block; }

  .service-cta {
    background-color: #cd553f;
    padding: 5rem 0;
    text-align: center;
  }

  .service-cta h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    font-weight: 700;
    text-transform: uppercase;
    color: #000;
    margin-bottom: 0.75rem;
  }

  .service-cta p {
    color: rgba(0,0,0,0.7);
    font-size: 1rem;
    margin-bottom: 2rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 900px) {
    .overview-inner { grid-template-columns: 1fr; gap: 3rem; }
    .day-badge { bottom: 1rem; right: 1rem; }
    .faq-grid, .mini-gallery { grid-template-columns: 1fr; }
  }
</style>
