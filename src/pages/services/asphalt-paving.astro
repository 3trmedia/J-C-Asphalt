---
import Layout from '../../layouts/Layout.astro';

const process = [
  { step: '01', title: 'Free Estimate', desc: 'We assess your site, take measurements, and provide a detailed written quote at no charge.' },
  { step: '02', title: 'Site Prep', desc: 'Our crew clears, grades, and compacts the sub-base to ensure a stable foundation for your asphalt.' },
  { step: '03', title: 'Paving', desc: 'Hot-mix asphalt is laid and compacted by our team using professional-grade equipment.' },
  { step: '04', title: 'Finishing', desc: 'Edges are clean-cut, surface is rolled smooth, and the site is cleaned up before we leave.' },
];
---

<Layout
  title="Asphalt Paving Services | J&C Asphalt | Utah Valley"
  description="Professional asphalt paving services throughout Utah Valley. J&C Asphalt brings a full crew to every job. Most projects completed in a single day."
>
  <section class="service-hero">
    <div class="container">
      <span class="section-label">Our Services</span>
      <h1 class="section-title">Asphalt Paving &amp; Maintenance</h1>
      <p>New installation, overlays, crack repair, and full-depth reclamation. Our crew handles every phase of asphalt paving with professional equipment and proven technique.</p>
      <div class="hero-ctas">
        <a href="/contact" class="btn-primary">Get a Free Quote</a>
        <a href="/work" class="btn-outline">See Our Work</a>
      </div>
    </div>
  </section>

  <section class="service-overview section-pad">
    <div class="container">
      <div class="overview-inner">
        <div class="overview-image">
          <img
            src="/images/crew-asphalt-raking.jpg"
            alt="J&C Asphalt crew member raking fresh asphalt on a Utah Valley paving project"
            width="580"
            height="480"
            loading="lazy"
          />
        </div>
        <div class="overview-content">
          <span class="section-label">What We Offer</span>
          <h2 class="section-title">Full-Service Asphalt Paving</h2>
          <p>Whether you need a brand-new asphalt surface or repairs to an existing one, J&amp;C Asphalt has the crew and equipment to handle it. We work on residential driveways, commercial parking lots, private roads, and more.</p>
          <ul class="service-list">
            <li>New asphalt installation</li>
            <li>Asphalt overlay (over existing surface)</li>
            <li>Full-depth reclamation</li>
            <li>Pothole and crack repair</li>
            <li>Asphalt maintenance and sealcoating</li>
            <li>Edge repair and patching</li>
          </ul>
          <a href="/contact" class="btn-primary" style="margin-top: 1.75rem; display: inline-block;">Request a Quote</a>
        </div>
      </div>
    </div>
  </section>

  <section class="process-section section-pad section-dark">
    <div class="container">
      <div class="section-header">
        <span class="section-label">How It Works</span>
        <h2 class="section-title">Our Paving Process</h2>
      </div>
      <div class="process-grid">
        {process.map(p => (
          <div class="process-step">
            <span class="step-number">{p.step}</span>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="service-pad section-pad">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Recent Work</span>
        <h2 class="section-title">Asphalt Projects</h2>
      </div>
      <div class="mini-gallery">
        {['/images/paver-leeboy-side.jpg', '/images/aerial-paver-top.jpg', '/images/asphalt-road-green.jpg'].map((src, i) => (
          <div class="gallery-item">
            <img
              src={src}
              alt={`J&C Asphalt paving project ${i + 1}`}
              width="560"
              height="380"
              loading="lazy"
            />
          </div>
        ))}
      </div>
      <div style="text-align:center; margin-top: 2.5rem;">
        <a href="/work" class="btn-outline-red">View All Projects &rarr;</a>
      </div>
    </div>
  </section>

  <section class="service-cta">
    <div class="container">
      <h2>Ready for a Professional Asphalt Quote?</h2>
      <p>We'll assess your project and provide a written estimate, fast, free, and with no pressure.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn-primary">Get a Free Quote</a>
        <a href="tel:+14354064640" class="btn-outline">Call (435) 406-4640</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .service-hero {
    padding: 8rem 0 5rem;
    background-color: #FFFFFF;
    border-bottom: 3px solid #cd553f;
  }

  .service-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0.5rem 0 1rem;
  }

  .service-hero p {
    color: #666;
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 620px;
    margin-bottom: 1.75rem;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .section-pad {
    padding: 5rem 0;
  }

  .section-dark {
    background-color: #F2F5F2;
  }

  .section-header {
    text-align: center;
    max-width: 580px;
    margin: 0 auto 3rem;
  }

  .overview-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .overview-image img {
    width: 100%;
    height: 480px;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .overview-content h2 {
    margin: 0.5rem 0 1rem;
  }

  .overview-content p {
    color: #666;
    font-size: 0.95rem;
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .service-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .service-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: #555;
  }

  .service-list li::before {
    content: '';
    width: 18px;
    height: 18px;
    background-image: url("data:image/svg+xml,%3Csvg width='18' height='18' viewBox='0 0 18 18' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M3 9l4 4 8-8' stroke='%23cd553f' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: center;
    flex-shrink: 0;
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .process-step {
    padding: 2rem;
    background-color: #FFFFFF;
    border: 1px solid #C8CEC8;
    border-top: 3px solid #cd553f;
  }

  .step-number {
    display: block;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 3rem;
    font-weight: 700;
    color: rgba(205, 85, 63, 0.2);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .process-step h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    color: #121212;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .process-step p {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.6;
    margin: 0;
  }

  .mini-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .gallery-item img {
    width: 100%;
    height: 380px;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .service-cta {
    background-color: #cd553f;
    padding: 5rem 0;
    text-align: center;
  }

  .service-cta h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    font-weight: 700;
    text-transform: uppercase;
    color: #000;
    margin-bottom: 0.75rem;
  }

  .service-cta p {
    color: rgba(0,0,0,0.7);
    font-size: 1rem;
    margin-bottom: 2rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .service-cta .btn-primary {
    background-color: #000;
    color: #cd553f;
  }

  .service-cta .btn-primary:hover {
    background-color: #1A1A1A;
  }

  .service-cta .btn-outline {
    border-color: #000;
    color: #000;
  }

  .service-cta .btn-outline:hover {
    background-color: #000;
    color: #cd553f;
  }

  @media (max-width: 900px) {
    .overview-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .process-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .mini-gallery {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 580px) {
    .process-grid,
    .mini-gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
