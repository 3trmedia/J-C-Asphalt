---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Parking Lot Paving | J&C Asphalt — Utah Valley Commercial Paving"
  description="Commercial and HOA parking lot paving throughout Utah Valley. J&C Asphalt handles large-scale paving projects with a full professional crew and industrial equipment."
>
  <section class="service-hero">
    <div class="container">
      <span class="section-label">Commercial Services</span>
      <h1 class="section-title">Parking Lot Paving &amp; Maintenance</h1>
      <p>From HOA lots to church parking areas to commercial properties — J&amp;C Asphalt has the crew size and equipment to handle large-scale paving projects efficiently and professionally.</p>
      <div class="hero-ctas">
        <a href="/contact" class="btn-primary">Get a Commercial Quote</a>
        <a href="/work" class="btn-outline">See Our Projects</a>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container">
      <div class="overview-inner">
        <div class="overview-image">
          <img
            src="/images/parking-completed.jpg"
            alt="Commercial parking lot paved by J&C Asphalt in Utah Valley"
            width="580"
            height="460"
            loading="lazy"
          />
        </div>
        <div class="overview-content">
          <span class="section-label">What We Offer</span>
          <h2 class="section-title">Full-Scale Commercial Paving</h2>
          <p>Small crews can't handle large parking lots efficiently. With 15+ crew members and industrial paving equipment, J&amp;C Asphalt can complete large commercial lots in a fraction of the time it would take a smaller operation.</p>
          <p>We work with HOAs, churches, retail centers, warehouses, and private property owners across Utah Valley and beyond.</p>
          <ul class="service-list">
            <li>New parking lot installation</li>
            <li>Asphalt overlay on existing lots</li>
            <li>Full-depth removal and replacement</li>
            <li>Crack sealing and maintenance</li>
            <li>Parking lot striping and markings</li>
            <li>ADA compliance striping and curb work</li>
          </ul>
          <a href="/contact" class="btn-primary" style="margin-top: 2rem; display: inline-block;">Request a Commercial Quote</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad section-dark">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Who We Work With</span>
        <h2 class="section-title">Commercial Clients We Serve</h2>
      </div>
      <div class="client-types">
        {[
          { icon: '🏘', title: 'HOAs', desc: 'Parking lots, private roads, and common area paving for homeowners associations.' },
          { icon: '⛪', title: 'Churches & Institutions', desc: 'Large parking lots for churches, schools, and community organizations.' },
          { icon: '🏭', title: 'Commercial & Industrial', desc: 'Warehouses, storage facilities, retail centers, and industrial sites.' },
          { icon: '🏢', title: 'Property Management', desc: 'Multi-unit residential and commercial property paving maintenance.' },
        ].map(c => (
          <div class="client-card">
            <div class="client-icon">{c.icon}</div>
            <h3>{c.title}</h3>
            <p>{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Recent Work</span>
        <h2 class="section-title">Parking Lot Projects</h2>
      </div>
      <div class="mini-gallery">
        {['/images/aerial-2.jpg', '/images/parking-night.jpg', '/images/crew-work-6.jpg'].map((src, i) => (
          <img
            src={src}
            alt={`Commercial parking lot project ${i + 1} by J&C Asphalt`}
            width="560"
            height="380"
            loading="lazy"
          />
        ))}
      </div>
      <div style="text-align:center; margin-top: 2.5rem;">
        <a href="/work" class="btn-outline-red">View All Projects &rarr;</a>
      </div>
    </div>
  </section>

  <section class="service-cta">
    <div class="container">
      <h2>Get a Commercial Paving Quote</h2>
      <p>Large lot? No problem. We'll assess your site and deliver a competitive written quote fast.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn-primary" style="background:#000; color:#cd553f;">Get a Quote</a>
        <a href="tel:+14354064640" class="btn-outline" style="border-color:#000; color:#000;">Call (435) 406-4640</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .service-hero {
    padding: 8rem 0 5rem;
    background-color: #111111;
    border-bottom: 3px solid #cd553f;
  }

  .service-hero h1 { font-size: clamp(2rem, 4vw, 3rem); margin: 0.5rem 0 1rem; }
  .service-hero p { color: #888; font-size: 1.05rem; line-height: 1.7; max-width: 640px; margin-bottom: 1.75rem; }
  .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
  .section-pad { padding: 5rem 0; }
  .section-dark { background-color: #111111; }

  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3rem;
  }

  .overview-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .overview-image img { width: 100%; height: 460px; object-fit: cover; object-position: center; display: block; }
  .overview-content h2 { margin: 0.5rem 0 1rem; }
  .overview-content p { color: #888; font-size: 0.95rem; line-height: 1.75; margin-bottom: 1rem; }

  .service-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .service-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: #B0B0B0;
  }

  .service-list li::before {
    content: '';
    width: 18px;
    height: 18px;
    background-image: url("data:image/svg+xml,%3Csvg width='18' height='18' viewBox='0 0 18 18' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M3 9l4 4 8-8' stroke='%23cd553f' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: center;
    flex-shrink: 0;
  }

  .client-types {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .client-card {
    padding: 2rem;
    background-color: #1A1A1A;
    border: 1px solid #2A2A2A;
    text-align: center;
    transition: border-color 0.2s;
  }

  .client-card:hover { border-color: #cd553f; }

  .client-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .client-card h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    text-transform: uppercase;
    color: #F0F0F0;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .client-card p {
    font-size: 0.85rem;
    color: #888;
    line-height: 1.6;
  }

  .mini-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .mini-gallery img { width: 100%; height: 380px; object-fit: cover; object-position: center; display: block; }

  .service-cta {
    background-color: #cd553f;
    padding: 5rem 0;
    text-align: center;
  }

  .service-cta h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    font-weight: 700;
    text-transform: uppercase;
    color: #000;
    margin-bottom: 0.75rem;
  }

  .service-cta p {
    color: rgba(0,0,0,0.7);
    font-size: 1rem;
    margin-bottom: 2rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 900px) {
    .overview-inner { grid-template-columns: 1fr; gap: 3rem; }
    .client-types { grid-template-columns: repeat(2, 1fr); }
    .mini-gallery { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 580px) {
    .client-types, .mini-gallery { grid-template-columns: 1fr; }
  }
</style>
