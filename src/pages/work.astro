---
import Layout from '../layouts/Layout.astro';

const projects = [
  { title: 'Residential Driveway', location: 'Spanish Fork, UT', type: 'Paving', size: '2,400 sq ft', img: '/images/crew-work-2.jpg' },
  { title: 'Commercial Parking Lot', location: 'Provo, UT', type: 'Parking Lot', size: '18,000 sq ft', img: '/images/parking-completed.jpg' },
  { title: 'Driveway Installation', location: 'Springville, UT', type: 'Paving', size: '1,800 sq ft', img: '/images/crew-work-3.jpg' },
  { title: 'Land Clearing + Paving', location: 'Payson, UT', type: 'Land Clearing', size: '5,000 sq ft', img: '/images/land-house.jpg' },
  { title: 'HOA Parking Lot', location: 'Orem, UT', type: 'Parking Lot', size: '22,000 sq ft', img: '/images/aerial-2.jpg' },
  { title: 'Aggregate Driveway', location: 'Mapleton, UT', type: 'Aggregate', size: '3,200 sq ft', img: '/images/parking-closeup.jpg' },
  { title: 'Private Road Paving', location: 'Salem, UT', type: 'Paving', size: '8,500 sq ft', img: '/images/aerial-1.jpg' },
  { title: 'Concrete Curb & Gutter', location: 'American Fork, UT', type: 'Concrete', size: '600 ln ft', img: '/images/concrete-finished.jpg' },
  { title: 'Driveway Overlay', location: 'Lehi, UT', type: 'Paving', size: '2,100 sq ft', img: '/images/crew-work-10.jpg' },
  { title: 'Church Parking Lot', location: 'Pleasant Grove, UT', type: 'Parking Lot', size: '30,000 sq ft', img: '/images/parking-night.jpg' },
  { title: 'Residential Driveway', location: 'Santaquin, UT', type: 'Paving', size: '1,950 sq ft', img: '/images/crew-work-8.jpg' },
  { title: 'Prep Work + Grading', location: 'Provo, UT', type: 'Land Clearing', size: '12,000 sq ft', img: '/images/land-farm.jpg' },
];

const filters = ['All', 'Paving', 'Parking Lot', 'Aggregate', 'Concrete', 'Land Clearing'];
---

<Layout
  title="Our Work | J&C Asphalt Project Gallery"
  description="Browse J&C Asphalt's project portfolio — residential driveways, commercial parking lots, and asphalt paving work across Utah Valley."
>
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="container">
      <span class="section-label">Project Portfolio</span>
      <h1 class="section-title">Real Jobs. Real Results.</h1>
      <p>Every project completed by our crew. Browse our work across Utah Valley and see what a professional paving team delivers.</p>
    </div>
  </section>

  <!-- PROJECT GALLERY -->
  <section class="section-pad section-dark">
    <div class="container">

      <!-- Filter Bar -->
      <div class="filter-bar" id="filter-bar">
        {filters.map(f => (
          <button class={`filter-btn${f === 'All' ? ' active' : ''}`} data-filter={f}>{f}</button>
        ))}
      </div>

      <div class="projects-grid" id="projects-grid">
        {projects.map(p => (
          <div class="project-card" data-type={p.type}>
            <div class="project-img">
              <img
                src={p.img}
                alt={`${p.title} in ${p.location} — J&C Asphalt`}
                width="600"
                height="420"
                loading="lazy"
              />
              <span class="project-type">{p.type}</span>
            </div>
            <div class="project-info">
              <div>
                <strong>{p.title}</strong>
                <span class="location">{p.location}</span>
              </div>
              <span class="size">{p.size}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="work-cta">
    <div class="container">
      <span class="section-label">Your Project Could Be Next</span>
      <h2>Ready to Add Your Driveway to This List?</h2>
      <a href="/contact" class="btn-primary">Get a Free Quote</a>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 8rem 0 5rem;
    background-color: #FFFFFF;
    border-bottom: 3px solid #cd553f;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0.5rem 0 1rem;
  }

  .page-hero p {
    color: #666;
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 580px;
  }

  .section-pad {
    padding: 5rem 0;
  }

  .section-dark {
    background-color: #F2F5F2;
  }

  .filter-bar {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .filter-btn {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.5rem 1.25rem;
    border: 1px solid #C8CEC8;
    background: transparent;
    color: #666;
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-btn:hover,
  .filter-btn.active {
    border-color: #cd553f;
    background-color: #cd553f;
    color: #000;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .project-card {
    background-color: #FFFFFF;
    border: 1px solid #C8CEC8;
    overflow: hidden;
    transition: border-color 0.2s, opacity 0.3s;
  }

  .project-card:hover {
    border-color: #cd553f;
  }

  .project-card.hidden {
    display: none;
  }

  .project-img {
    position: relative;
    overflow: hidden;
  }

  .project-img img {
    width: 100%;
    height: 240px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .project-card:hover .project-img img {
    transform: scale(1.04);
  }

  .project-type {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background-color: #cd553f;
    color: #000;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
  }

  .project-info {
    padding: 1rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .project-info strong {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    text-transform: uppercase;
    color: #121212;
    display: block;
    margin-bottom: 0.2rem;
  }

  .location {
    font-size: 0.8rem;
    color: #666;
  }

  .size {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.8rem;
    color: #cd553f;
    letter-spacing: 0.05em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .work-cta {
    background-color: #E8EBE8;
    padding: 5rem 0;
    text-align: center;
    border-top: 1px solid #D0D5D0;
  }

  .work-cta h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    text-transform: uppercase;
    color: #121212;
    margin: 0.5rem 0 2rem;
  }

  @media (max-width: 900px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 580px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.project-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.dataset.filter;

      cards.forEach(card => {
        if (filter === 'All' || card.dataset.type === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
