---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'J&C Asphalt — Utah Valley\'s professional asphalt paving team. Full-crew driveway and parking lot installation serving Spanish Fork to Salt Lake City.',
  ogImage = '/images/og-default.jpg'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- Favicon placeholder -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Schema: Local Business -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "J&C Asphalt",
        "image": "https://jcasphaltpaving.com/images/og-default.jpg",
        "telephone": "+14354064640",
        "email": "jcasphalt.contracting@gmail.com",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Provo",
          "addressRegion": "UT",
          "addressCountry": "US"
        },
        "openingHours": "Mo-Fr 09:00-18:00",
        "areaServed": ["Provo", "Orem", "Spanish Fork", "Springville", "Payson", "Lehi", "American Fork", "Pleasant Grove", "Lindon", "Mapleton", "Salem", "Santaquin"],
        "priceRange": "$$",
        "url": "https://jcasphaltpaving.com"
      }
    </script>

    <slot name="head" />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
